# Copy to .env.docker for local Docker Compose: cp .env.docker.example .env.docker
# Do not use in production without replacing secrets and URLs.

NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/expirymate?schema=public

CORS_ORIGIN_ADMIN=http://localhost:3000
CORS_ORIGIN_MOBILE=http://localhost:8081
DEFAULT_OWNER_KEY=demo-user
AUTH_TOKEN_SECRET=local-docker-auth-token-secret-min-32-chars
AUTH_ALLOW_DEV_FALLBACK=false
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_DAYS=30

APP_BASE_URL=expirymate://
ADMIN_BASE_URL=http://localhost:3000

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ExpiryMate <no-reply@expirymate.local>

APPLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
KAKAO_OAUTH_CLIENT_ID=
NAVER_OAUTH_CLIENT_ID=
NAVER_OAUTH_CLIENT_SECRET=

PRIVACY_POLICY_URL=http://localhost:3000/privacy
PRIVACY_CHOICES_URL=http://localhost:3000/privacy/choices
PRIVACY_CONTACT_EMAIL=privacy@expirymate.local

OPENAI_API_KEY=
PUSH_REMINDER_SCHEDULER_ENABLED=false

IAP_ALLOWED_PRODUCT_IDS=expirymate_premium_monthly,expirymate_premium_yearly
APPLE_BUNDLE_ID=com.expirymate.mobile
APPLE_APP_STORE_ENVIRONMENT=sandbox
APPLE_APP_STORE_ISSUER_ID=
APPLE_APP_STORE_KEY_ID=
APPLE_APP_STORE_PRIVATE_KEY=
GOOGLE_PLAY_PACKAGE_NAME=com.expirymate.mobile
GOOGLE_PLAY_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PLAY_SERVICE_ACCOUNT_PRIVATE_KEY=

# Admin (docker-compose admin service — also required as Docker build-args)
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
PRIVACY_CONTACT_EMAIL=privacy@expirymate.local

# Release tagging (optional — set at Docker/CI build time)
GIT_SHA=local

# Sentry (optional — leave empty to disable). See docs/PROJECT.md §5.
# jango-api → SENTRY_DSN | jango-admin → SENTRY_DSN + NEXT_PUBLIC_SENTRY_DSN | jango-mobile → EXPO_PUBLIC_SENTRY_DSN
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_DSN=
