{
  "name": "@expirymate/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "predev": "pnpm --filter @expirymate/shared build",
    "pretypecheck": "pnpm --filter @expirymate/shared build",
    "dev": "expo start -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "eas:config": "eas config",
    "eas:build:ios": "eas build --platform ios --profile production",
    "eas:submit:ios": "eas submit --platform ios --profile production",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@expirymate/shared": "workspace:*",
    "@hookform/resolvers": "^5.2.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@sentry/react-native": "^8.17.1",
    "@tanstack/react-query": "^5.87.1",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.11",
    "expo-constants": "~18.0.13",
    "expo-notifications": "~0.32.12",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "lucide-react-native": "^1.11.0",
    "react": "19.1.0",
    "react-hook-form": "^7.62.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "zod": "^4.1.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@types/react": "^19.1.17",
    "babel-preset-expo": "^54.0.10"
  }
}
