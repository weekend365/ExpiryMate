{
  "name": "@expirymate/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "predev": "pnpm --filter @expirymate/shared build",
    "pretypecheck": "pnpm --filter @expirymate/shared build",
    "dev": "expo start -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "eas:config": "pnpm run eas:config:ios && pnpm run eas:config:android",
    "eas:config:ios": "pnpm dlx eas-cli@21.2.0 config --platform ios --profile production --non-interactive",
    "eas:config:android": "pnpm dlx eas-cli@21.2.0 config --platform android --profile production --non-interactive",
    "eas:build:ios": "pnpm dlx eas-cli@21.2.0 build --platform ios --profile production",
    "eas:build:ios:preview": "pnpm dlx eas-cli@21.2.0 build --platform ios --profile preview",
    "eas:build:android": "pnpm dlx eas-cli@21.2.0 build --platform android --profile production",
    "eas:submit:ios": "pnpm dlx eas-cli@21.2.0 submit --platform ios --profile production",
    "eas:submit:android": "pnpm dlx eas-cli@21.2.0 submit --platform android --profile production",
    "eas-build-pre-install": "corepack enable && corepack prepare pnpm@9.15.0 --activate",
    "eas-build-post-install": "cd ../.. && pnpm --filter @expirymate/shared build && node apps/mobile/scripts/validate-public-env.cjs && node -e \"require('./apps/mobile/scripts/ios-team-env.cjs').assertIosTeamCompatibleWithAppEnv()\"",
    "validate:env": "node ./scripts/validate-public-env.cjs",
    "validate:ios-team": "node ./scripts/ios-team-env.cjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "branding:sync": "python3 scripts/sync-branding-from-jango.py"
  },
  "dependencies": {
    "@expirymate/shared": "workspace:*",
    "@expo/metro-runtime": "~6.1.2",
    "@hookform/resolvers": "^5.2.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-ml-kit/barcode-scanning": "^2.0.0",
    "@react-native-ml-kit/text-recognition": "^2.0.0",
    "@sentry/react-native": "^7.2.0",
    "@tanstack/react-query": "^5.87.1",
    "expo": "~54.0.36",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.11",
    "expo-build-properties": "^1.0.10",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "lucide-react-native": "^1.11.0",
    "react": "19.1.0",
    "react-hook-form": "^7.62.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "zod": "^4.1.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@types/react": "^19.1.17",
    "babel-preset-expo": "^54.0.10"
  }
}
