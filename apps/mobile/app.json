{
  "expo": {
    "name": "장고야 부탁해",
    "slug": "expirymate",
    "description": "Jango (장고야 부탁해) — Korean-first ingredient inventory, expiry reminder, and recipe recommendation app.",
    "platforms": [
      "ios",
      "android"
    ],
    "scheme": "expirymate",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F1F3F5",
    "primaryColor": "#10B981",
    "icon": "./assets/branding/icon.png",
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Pretendard-Regular.otf",
            "./assets/fonts/Pretendard-Medium.otf",
            "./assets/fonts/Pretendard-SemiBold.otf",
            "./assets/fonts/Pretendard-Bold.otf",
            "./assets/fonts/Pretendard-ExtraBold.otf"
          ]
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/branding/notification-icon.png",
          "color": "#10B981",
          "defaultChannel": "expiry-reminders"
        }
      ],
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "image": "./assets/branding/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#F1F3F5"
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-camera",
        {
          "cameraPermission": "바코드와 유통기한을 스캔해 식재료를 등록하려면 카메라 접근이 필요합니다.",
          "recordAudioAndroid": false
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4"
          }
        }
      ],
      [
        "@sentry/react-native",
        {
          "organization": "expirymate",
          "project": "mobile"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.expirymate.mobile",
      "buildNumber": "1",
      "icon": "./assets/branding/icon.png",
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ],
        "aps-environment": "development"
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "CFBundleDevelopmentRegion": "ko",
        "CFBundleDisplayName": "장고야 부탁해",
        "NSCameraUsageDescription": "바코드와 유통기한을 스캔해 식재료를 등록하려면 카메라 접근이 필요합니다."
      }
    },
    "android": {
      "package": "com.expirymate.mobile",
      "versionCode": 1,
      "permissions": [
        "CAMERA"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "icon": "./assets/branding/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/adaptive-icon.png",
        "backgroundColor": "#F1F3F5"
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6c64c29f-a2bb-4416-99c3-0b4d88898ea6"
      }
    },
    "owner": "devnamu"
  }
}
