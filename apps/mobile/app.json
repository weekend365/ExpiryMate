{
  "expo": {
    "name": "ExpiryMate",
    "slug": "expirymate-mobile",
    "scheme": "expirymate",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router",
      "expo-notifications",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.expirymate.mobile"
    }
  }
}
