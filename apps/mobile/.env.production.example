EXPO_PUBLIC_API_BASE_URL="https://api.expirymate.app"
EXPO_PUBLIC_APP_ENV="production"
EXPO_PUBLIC_IAP_PRODUCT_IDS="expirymate_premium_monthly,expirymate_premium_yearly"
# Same https origin as API_BASE_URL; path must end with /oauth/callback
EXPO_PUBLIC_OAUTH_REDIRECT_URI="https://api.expirymate.app/oauth/callback"
# Replace with real client ids in EAS secrets (no "your-*" placeholders)
EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID="1234567890-abc.apps.googleusercontent.com"
EXPO_PUBLIC_KAKAO_OAUTH_CLIENT_ID="kakaoRestApiKey"
# Optional — omit or leave empty to hide Naver login
EXPO_PUBLIC_NAVER_OAUTH_CLIENT_ID=""
# Set via EAS secret in real deploys (do not commit). Sentry project: jango-mobile.
EXPO_PUBLIC_SENTRY_DSN=""
