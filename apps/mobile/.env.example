EXPO_PUBLIC_API_BASE_URL="http://localhost:4000"
EXPO_PUBLIC_APP_ENV="development"
# Personal Team(무료 Apple ID)로 실기기 빌드 시 1로 설정 (Push/Apple 로그인 entitlement 제외)
# EXPO_IOS_PERSONAL_TEAM=1
EXPO_PUBLIC_IAP_PRODUCT_IDS="expirymate_premium_monthly,expirymate_premium_yearly"
# Kakao/Naver/Google Redirect URI (must be http(s) — custom schemes are rejected)
EXPO_PUBLIC_OAUTH_REDIRECT_URI="https://api-production-1504.up.railway.app/oauth/callback"
EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=""
EXPO_PUBLIC_KAKAO_OAUTH_CLIENT_ID=""
EXPO_PUBLIC_NAVER_OAUTH_CLIENT_ID=""
# Optional. Preview/production: EAS secret EXPO_PUBLIC_SENTRY_DSN.
# Sentry project: jango-mobile (React Native). Ignored when EXPO_PUBLIC_APP_ENV=development.
# Never commit a real DSN. See docs/PROJECT.md §5 Sentry.
EXPO_PUBLIC_SENTRY_DSN=""
