{
  "name": "@expirymate/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "pnpm --filter @expirymate/shared build",
    "pretypecheck": "pnpm --filter @expirymate/shared build",
    "dev": "nest start --watch",
    "build": "pnpm --filter @expirymate/shared build && nest build",
    "start": "node dist/main.js",
    "lint": "eslint src prisma --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "NODE_ENV=development tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@expirymate/shared": "workspace:*",
    "@nestjs/common": "^11.0.7",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.7",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.0.7",
    "@prisma/client": "^6.6.0",
    "@sentry/nestjs": "^10.63.0",
    "@sentry/node": "^10.63.0",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "helmet": "^8.2.0",
    "nodemailer": "^8.0.10",
    "openai": "^6.37.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@types/express": "^5.0.6",
    "@types/helmet": "^4.0.0",
    "@types/nodemailer": "^8.0.0",
    "prisma": "^6.6.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.3"
  }
}
