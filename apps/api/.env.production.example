NODE_ENV="production"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/expirymate?schema=public"
PORT=4000
CORS_ORIGIN_ADMIN="https://admin.your-domain.com"
CORS_ORIGIN_MOBILE="https://app.your-domain.com"
DEFAULT_OWNER_KEY="demo-user"
AUTH_TOKEN_SECRET="generate-a-random-secret-at-least-32-characters"
AUTH_ALLOW_DEV_FALLBACK="false"
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_DAYS=30
# Shared across API replicas. Use memory only for deliberate single-process debugging.
AUTH_RATE_LIMIT_STORE="database"
# Trust one reverse-proxy hop so auth rate limits use the real client IP.
TRUST_PROXY="1"
APP_BASE_URL="expirymate://"
ADMIN_BASE_URL="https://admin.your-domain.com"
SMTP_HOST="smtp.your-provider.com"
SMTP_PORT=587
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"
# Korean/spaced names: "\"장고야 부탁해\" <noreply@mail.your-domain.com>"
SMTP_FROM="Jango <noreply@mail.your-domain.com>"
APPLE_OAUTH_CLIENT_ID="com.expirymate.mobile"
GOOGLE_OAUTH_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_OAUTH_CLIENT_SECRET="your-google-client-secret"
KAKAO_OAUTH_CLIENT_ID="your-kakao-rest-api-key"
KAKAO_OAUTH_CLIENT_SECRET="your-kakao-client-secret-if-enabled"
# Optional — omit both to disable Naver login in production
NAVER_OAUTH_CLIENT_ID="your-naver-client-id"
NAVER_OAUTH_CLIENT_SECRET="your-naver-client-secret"
OAUTH_PROVIDER_REDIRECT_URI="https://api.your-domain.com/oauth/callback"
OAUTH_APP_RETURN_URIS="expirymate://oauth"
# Public HTTPS API host for email verify/reset bridge links (required in production)
AUTH_LINK_BASE_URL="https://api.your-domain.com"
PRIVACY_POLICY_URL="https://admin.your-domain.com/privacy"
PRIVACY_CHOICES_URL="https://admin.your-domain.com/privacy/choices"
PRIVACY_CONTACT_EMAIL="privacy@your-domain.com"
AI_DATA_NOTICE_VERSION="ai-data-notice-v1"
OPENAI_API_KEY="sk-..."
RECIPE_AI_MODEL="gpt-5.4-mini"
RECIPE_AI_ENABLED="true"
RECIPE_RATE_LIMIT_MAX=3
RECIPE_RATE_LIMIT_WINDOW_SECONDS=60
RECIPE_DAILY_QUOTA=20
RECIPE_CACHE_TTL_SECONDS=21600
RECIPE_DAILY_COST_LIMIT_USD=1
RECIPE_GLOBAL_DAILY_COST_LIMIT_USD=10
RECIPE_MAX_INFLIGHT=5
RECIPE_AI_MAX_OUTPUT_TOKENS=2500
RECIPE_AI_INPUT_COST_PER_1M_TOKENS=0.25
RECIPE_AI_CACHED_INPUT_COST_PER_1M_TOKENS=0.025
RECIPE_AI_OUTPUT_COST_PER_1M_TOKENS=2
PUSH_REMINDER_SCHEDULER_ENABLED="false"
PUSH_REMINDER_SCHEDULER_INTERVAL_MINUTES=30
PUSH_REMINDER_DELIVERY_HOUR=9
PUSH_REMINDER_MAX_ATTEMPTS=3
PUSH_REMINDER_TIMEZONE_OFFSET_MINUTES=540
PUSH_REMINDER_STALE_PENDING_MINUTES=15
PUSH_REMINDER_RECEIPT_MIN_AGE_MINUTES=5
PUSH_REMINDER_RECEIPT_BATCH_SIZE=100
EXPO_PUSH_ACCESS_TOKEN=""
IAP_ALLOWED_PRODUCT_IDS="expirymate_premium_monthly,expirymate_premium_yearly"
# Production must stay false/unset. Set true only for deliberate sandbox QA deploys.
IAP_ALLOW_SANDBOX_PURCHASES="false"
APPLE_BUNDLE_ID="com.expirymate.mobile"
APPLE_APP_STORE_ENVIRONMENT="production"
APPLE_APP_STORE_ISSUER_ID="your-app-store-connect-issuer-id"
APPLE_APP_STORE_KEY_ID="your-app-store-connect-key-id"
APPLE_APP_STORE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GOOGLE_PLAY_PACKAGE_NAME="com.expirymate.mobile"
GOOGLE_PLAY_SERVICE_ACCOUNT_EMAIL="iap-verifier@your-project.iam.gserviceaccount.com"
GOOGLE_PLAY_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# Observability — Sentry project jango-api. Set on Railway; never commit a real DSN.
SENTRY_DSN=""
GIT_SHA=""
