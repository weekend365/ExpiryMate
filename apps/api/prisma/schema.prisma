generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StorageLocation {
  fridge
  freezer
  room
  bathroom
  kitchen
}

enum ItemStatus {
  active
  consumed
  discarded
  expired
}

enum ExpirySource {
  manual
  preset
  ocr_detected
}

enum ProductCategory {
  dairy
  egg
  tofu
  beverage
  instant_food
  personal_care
  paper_goods
  cleaning
  frozen_food
  produce
  seasoning
  snack
  household
}

enum UserRole {
  user
  admin
}

enum AccountType {
  anonymous
  registered
}

enum OAuthProvider {
  apple
  google
  kakao
}

enum OneTimeAuthTokenPurpose {
  email_verification
  password_reset
}

model User {
  id                    String           @id @default(cuid())
  email                 String?          @unique
  displayName           String?
  role                  UserRole         @default(user)
  accountType           AccountType      @default(anonymous)
  emailVerifiedAt       DateTime?
  aiDataNoticeAcceptedAt DateTime?
  aiDataNoticeVersion   String?
  deletedAt             DateTime?
  mergedIntoUserId      String?
  mergedIntoUser        User?            @relation("UserMerge", fields: [mergedIntoUserId], references: [id])
  mergedAnonymousUsers  User[]           @relation("UserMerge")
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  passwordCredential    PasswordCredential?
  oauthAccounts         OAuthAccount[]
  refreshSessions       RefreshSession[]
  oneTimeAuthTokens     OneTimeAuthToken[]
  inventoryItems        InventoryItem[]
  notificationPreference NotificationPreference?
  recipeRecommendations RecipeRecommendation[]

  @@index([accountType])
  @@index([role])
  @@index([deletedAt])
}

model PasswordCredential {
  userId            String   @id
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash      String
  passwordUpdatedAt DateTime @default(now())
}

model OAuthAccount {
  id             String        @id @default(cuid())
  provider       OAuthProvider
  providerUserId String
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  email          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([provider, providerUserId])
  @@index([userId])
}

model RefreshSession {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash       String    @unique
  expiresAt       DateTime
  revokedAt       DateTime?
  replacedByTokenHash String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId, expiresAt])
}

model OneTimeAuthToken {
  id         String                  @id @default(cuid())
  userId     String
  user       User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String                  @unique
  purpose    OneTimeAuthTokenPurpose
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime                @default(now())

  @@index([userId, purpose])
  @@index([purpose, expiresAt])
}

model Product {
  id             String          @id @default(cuid())
  name           String
  brand          String
  category       ProductCategory
  imageUrl       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  inventoryItems InventoryItem[]
}

model InventoryItem {
  id              String           @id @default(cuid())
  ownerKey        String           @default("demo-user")
  owner           User             @relation(fields: [ownerKey], references: [id])
  productId       String?
  product         Product?         @relation(fields: [productId], references: [id])
  displayName     String
  brand           String?
  category        ProductCategory?
  quantity        Int
  unit            String?          @default("개")
  storageLocation StorageLocation
  expiryDate      DateTime
  expirySource    ExpirySource
  status          ItemStatus       @default(active)
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([ownerKey, status])
  @@index([ownerKey, expiryDate])
}

model NotificationPreference {
  id                 String   @id @default(cuid())
  ownerKey           String   @unique @default("demo-user")
  owner              User     @relation(fields: [ownerKey], references: [id])
  enabled            Boolean  @default(true)
  reminderDaysBefore Int[]    @default([1, 3, 7])
  remindOnDayOf      Boolean  @default(true)
  quietHoursStart    String   @default("22:00")
  quietHoursEnd      String   @default("07:00")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model RecipeRecommendation {
  id                String   @id @default(cuid())
  ownerKey          String   @default("demo-user")
  owner             User     @relation(fields: [ownerKey], references: [id])
  requestCacheKey   String?
  request           Json
  inventorySnapshot Json
  recommendations   Json
  aiProvider        String
  aiModel           String
  promptVersion     String
  inputTokens       Int      @default(0)
  cachedInputTokens Int      @default(0)
  outputTokens      Int      @default(0)
  totalTokens       Int      @default(0)
  estimatedCostUsd  Decimal  @default(0) @db.Decimal(10, 6)
  createdAt         DateTime @default(now())

  @@index([ownerKey, createdAt])
  @@index([ownerKey, requestCacheKey, createdAt])
}
