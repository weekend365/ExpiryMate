generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ItemStatus {
  active
  consumed
  discarded
  expired
}

enum InventoryUnitCode {
  ea
  ml
  g
}

enum ExpirySource {
  manual
  preset
  ocr_detected
}

enum ProductCategory {
  dairy
  egg
  tofu
  beverage
  instant_food
  personal_care
  paper_goods
  cleaning
  frozen_food
  produce
  seasoning
  snack
  household
}

enum UserRole {
  user
  admin
}

enum AccountType {
  anonymous
  registered
}

enum OAuthProvider {
  apple
  google
  kakao
  naver
}

enum OneTimeAuthTokenPurpose {
  email_verification
  password_reset
}

enum SubscriptionStore {
  apple_app_store
  google_play
}

enum SubscriptionEntitlementStatus {
  active
  grace_period
  billing_retry
  paused
  expired
  revoked
  unknown
}

enum PushTokenPlatform {
  ios
  android
  web
  unknown
}

enum PushNotificationDeliveryStatus {
  pending
  sent
  failed
  skipped
}

enum InventorySpaceType {
  personal
  household
  store
}

enum InventorySpaceRole {
  owner
  manager
  member
}

enum SpaceInvitationMethod {
  email
  code
}

model User {
  id                         String                     @id @default(cuid())
  email                      String?                    @unique
  displayName                String?
  role                       UserRole                   @default(user)
  accountType                AccountType                @default(anonymous)
  emailVerifiedAt            DateTime?
  aiDataNoticeAcceptedAt     DateTime?
  aiDataNoticeVersion        String?
  deletedAt                  DateTime?
  mergedIntoUserId           String?
  mergedIntoUser             User?                      @relation("UserMerge", fields: [mergedIntoUserId], references: [id])
  mergedAnonymousUsers       User[]                     @relation("UserMerge")
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  passwordCredential         PasswordCredential?
  oauthAccounts              OAuthAccount[]
  refreshSessions            RefreshSession[]
  oneTimeAuthTokens          OneTimeAuthToken[]
  inventoryItems             InventoryItem[]
  notificationPreference     NotificationPreference?
  userStorageLocations       UserStorageLocation[]
  recipeRecommendations      RecipeRecommendation[]
  recipeFavorites            RecipeFavorite[]
  subscriptionEntitlements   SubscriptionEntitlement[]
  pushTokens                 PushToken[]
  pushNotificationDeliveries PushNotificationDelivery[]
  supportInquiries           SupportInquiry[]
  ownedInventorySpaces       InventorySpace[]           @relation("InventorySpaceOwner")
  inventorySpaceMemberships  InventorySpaceMembership[]
  sentSpaceInvitations       SpaceInvitation[]          @relation("SpaceInvitationSender")
  createdInventoryItems      InventoryItem[]            @relation("InventoryItemCreator")
  updatedInventoryItems      InventoryItem[]            @relation("InventoryItemUpdater")

  @@index([accountType])
  @@index([role])
  @@index([deletedAt])
}

model InventorySpace {
  id               String                     @id @default(cuid())
  name             String
  type             InventorySpaceType
  ownerUserId      String
  owner            User                       @relation("InventorySpaceOwner", fields: [ownerUserId], references: [id])
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  memberships      InventorySpaceMembership[]
  invitations      SpaceInvitation[]
  inventoryItems   InventoryItem[]
  storageLocations UserStorageLocation[]
  recommendations  RecipeRecommendation[]

  @@index([ownerUserId])
  @@index([type])
}

model InventorySpaceMembership {
  spaceId              String
  space                InventorySpace     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  userId               String
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  role                 InventorySpaceRole
  notificationsEnabled Boolean            @default(false)
  joinedAt             DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@id([spaceId, userId])
  @@index([userId, joinedAt])
  @@index([spaceId, role])
}

model SpaceInvitation {
  id              String                  @id @default(cuid())
  spaceId         String
  space           InventorySpace          @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  method          SpaceInvitationMethod   @default(email)
  email           String?
  role            InventorySpaceRole      @default(member)
  tokenHash       String                  @unique
  invitedByUserId String
  invitedBy       User                    @relation("SpaceInvitationSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime                @default(now())

  @@index([spaceId, email, createdAt])
  @@index([spaceId, method, createdAt])
  @@index([email, expiresAt])
}

model PasswordCredential {
  userId            String   @id
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash      String
  passwordUpdatedAt DateTime @default(now())
}

model OAuthAccount {
  id             String        @id @default(cuid())
  provider       OAuthProvider
  providerUserId String
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  email          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([provider, providerUserId])
  @@index([userId])
}

/// One-time authorize session: opaque state + PKCE verifier + allowlisted app return URI.
model OAuthAuthorizationSession {
  id           String        @id @default(cuid())
  state        String        @unique
  provider     OAuthProvider
  returnUri    String
  redirectUri  String
  codeVerifier String
  expiresAt    DateTime
  redirectedAt DateTime?
  consumedAt   DateTime?
  createdAt    DateTime      @default(now())

  @@index([expiresAt])
  @@index([provider, createdAt])
}

model RefreshSession {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash           String    @unique
  expiresAt           DateTime
  revokedAt           DateTime?
  replacedByTokenHash String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([userId, expiresAt])
}

/// Shared auth rate-limit counters (fixed window) for multi-instance API deploys.
model AuthRateLimitBucket {
  key             String   @id
  windowStartedAt DateTime
  hitCount        Int      @default(0)
  updatedAt       DateTime @updatedAt

  @@index([windowStartedAt])
}

model OneTimeAuthToken {
  id         String                  @id @default(cuid())
  userId     String
  user       User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String                  @unique
  purpose    OneTimeAuthTokenPurpose
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime                @default(now())

  @@index([userId, purpose])
  @@index([purpose, expiresAt])
}

model Product {
  id             String          @id @default(cuid())
  name           String
  brand          String
  category       ProductCategory
  imageUrl       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  inventoryItems InventoryItem[]
}

model ProductMaster {
  id                  String   @id @default(cuid())
  barcode             String   @unique
  name                String
  brand               String
  category            String
  imageUrl            String?
  source              String   @default("foodsafety_api")
  contributedByUserId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([name])
  @@index([category])
  @@index([source])
}

model InventoryItem {
  id                         String                     @id @default(cuid())
  ownerKey                   String                     @default("demo-user")
  owner                      User                       @relation(fields: [ownerKey], references: [id])
  spaceId                    String?
  space                      InventorySpace?            @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  createdByUserId            String?
  createdBy                  User?                      @relation("InventoryItemCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUserId            String?
  updatedBy                  User?                      @relation("InventoryItemUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  version                    Int                        @default(1)
  productId                  String?
  product                    Product?                   @relation(fields: [productId], references: [id])
  displayName                String
  brand                      String?
  category                   ProductCategory?
  quantity                   Int
  unit                       String?                    @default("개")
  quantityBase               Int                        @default(1)
  unitCode                   InventoryUnitCode          @default(ea)
  storageLocation            String
  expiryDate                 DateTime                   @db.Date
  expirySource               ExpirySource
  status                     ItemStatus                 @default(active)
  notes                      String?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  pushNotificationDeliveries PushNotificationDelivery[]

  @@index([ownerKey, status])
  @@index([ownerKey, expiryDate])
  @@index([spaceId, status])
  @@index([spaceId, expiryDate])
}

model NotificationPreference {
  id                 String   @id @default(cuid())
  ownerKey           String   @unique @default("demo-user")
  owner              User     @relation(fields: [ownerKey], references: [id])
  enabled            Boolean  @default(true)
  reminderDaysBefore Int[]    @default([1, 3, 7])
  remindOnDayOf      Boolean  @default(true)
  quietHoursStart    String   @default("22:00")
  quietHoursEnd      String   @default("07:00")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model UserStorageLocation {
  id        String          @id @default(cuid())
  ownerKey  String
  owner     User            @relation(fields: [ownerKey], references: [id], onDelete: Cascade)
  spaceId   String?
  space     InventorySpace? @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  key       String
  label     String
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([spaceId, key])
  @@index([ownerKey])
  @@index([spaceId])
}

model RecipeRecommendation {
  id                String          @id @default(cuid())
  ownerKey          String          @default("demo-user")
  owner             User            @relation(fields: [ownerKey], references: [id])
  spaceId           String?
  space             InventorySpace? @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  requestCacheKey   String?
  request           Json
  inventorySnapshot Json
  recommendations   Json
  aiProvider        String
  aiModel           String
  promptVersion     String
  inputTokens       Int             @default(0)
  cachedInputTokens Int             @default(0)
  outputTokens      Int             @default(0)
  totalTokens       Int             @default(0)
  estimatedCostUsd  Decimal         @default(0) @db.Decimal(10, 6)
  createdAt         DateTime        @default(now())

  @@index([ownerKey, createdAt])
  @@index([ownerKey, requestCacheKey, createdAt])
  @@index([spaceId, createdAt])
  @@index([spaceId, requestCacheKey, createdAt])
}

model RecipeFavorite {
  id                     String   @id @default(cuid())
  ownerKey               String
  owner                  User     @relation(fields: [ownerKey], references: [id])
  sourceRecommendationId String
  sourceDishIndex        Int
  dishSnapshot           Json
  inventorySnapshot      Json
  createdAt              DateTime @default(now())

  @@unique([ownerKey, sourceRecommendationId, sourceDishIndex])
  @@index([ownerKey, createdAt])
}

model SubscriptionEntitlement {
  id                    String                        @id @default(cuid())
  ownerKey              String
  owner                 User                          @relation(fields: [ownerKey], references: [id])
  store                 SubscriptionStore
  productId             String
  originalTransactionId String?
  transactionId         String?
  purchaseTokenHash     String?
  status                SubscriptionEntitlementStatus @default(unknown)
  isActive              Boolean                       @default(false)
  willRenew             Boolean?
  expiresAt             DateTime?
  environment           String?
  verifiedAt            DateTime                      @default(now())
  rawVerification       Json?
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt

  @@unique([store, originalTransactionId])
  @@unique([store, purchaseTokenHash])
  @@index([ownerKey, isActive, expiresAt])
  @@index([store, productId])
}

model PushToken {
  id         String                     @id @default(cuid())
  ownerKey   String
  owner      User                       @relation(fields: [ownerKey], references: [id], onDelete: Cascade)
  token      String                     @unique
  platform   PushTokenPlatform          @default(unknown)
  deviceId   String?
  appVersion String?
  enabled    Boolean                    @default(true)
  lastSeenAt DateTime                   @default(now())
  disabledAt DateTime?
  createdAt  DateTime                   @default(now())
  updatedAt  DateTime                   @updatedAt
  deliveries PushNotificationDelivery[]

  @@index([ownerKey, enabled])
}

model PushNotificationDelivery {
  id               String                         @id @default(cuid())
  ownerKey         String
  owner            User                           @relation(fields: [ownerKey], references: [id], onDelete: Cascade)
  pushTokenId      String
  pushToken        PushToken                      @relation(fields: [pushTokenId], references: [id], onDelete: Cascade)
  inventoryItemId  String
  inventoryItem    InventoryItem                  @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  reminderDate     DateTime
  daysBefore       Int
  status           PushNotificationDeliveryStatus @default(pending)
  expoTicketId     String?
  title            String
  body             String
  errorCode        String?
  errorMessage     String?
  attempts         Int                            @default(0)
  sentAt           DateTime?
  /// Set once Expo push receipts are fetched for expoTicketId (ok or error).
  receiptCheckedAt DateTime?
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt

  @@unique([pushTokenId, inventoryItemId, reminderDate, daysBefore])
  @@index([ownerKey, reminderDate])
  @@index([pushTokenId, status])
  @@index([status, receiptCheckedAt, sentAt])
  @@index([status, updatedAt])
}

/// Cross-instance lease so only one API replica runs the push reminder worker.
model SchedulerLease {
  key       String   @id
  ownerId   String
  expiresAt DateTime
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}

/// Append-only admin action trail (never update/delete from app code).
model AdminAuditLog {
  id           String   @id @default(cuid())
  actorUserId  String
  action       String
  resourceType String?
  resourceId   String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

enum SupportInquiryCategory {
  bug
  account
  recipe_ai
  other
}

enum SupportInquiryStatus {
  open
  closed
}

/// In-app customer support tickets (reply via email, not in-app thread).
model SupportInquiry {
  id         String                 @id @default(cuid())
  userId     String
  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   SupportInquiryCategory
  body       String
  appVersion String?
  platform   String?
  status     SupportInquiryStatus   @default(open)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([category, createdAt])
}
