# Railway Staging — API Service Variables
# Copy into Railway → api → Variables, then replace hostnames/secrets with real values.
# This file sets NODE_ENV=production, so keys must satisfy apps/api production-env.ts
# (https CORS/privacy/auth-link URLs, APPLE_APP_STORE_ENVIRONMENT=production, etc.).

NODE_ENV=production
PORT=4000

# Railway Postgres — use Variable Reference: ${{postgres.DATABASE_URL}}
DATABASE_URL=

# Generate: openssl rand -base64 48
AUTH_TOKEN_SECRET=
AUTH_ALLOW_DEV_FALLBACK=false
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_DAYS=30
AUTH_RATE_LIMIT_STORE=database
TRUST_PROXY=1

# Public HTTPS hosts after Railway domains are attached (see docs/PROJECT.md)
CORS_ORIGIN_ADMIN=https://admin-staging.up.railway.app
# Native RN does not send Origin; keep an https origin for Expo web / CORS allowlist.
CORS_ORIGIN_MOBILE=https://app-staging.up.railway.app
ADMIN_BASE_URL=https://admin-staging.up.railway.app
# Public HTTPS API host for email verify/reset bridge links (required)
AUTH_LINK_BASE_URL=https://api-staging.up.railway.app
PRIVACY_POLICY_URL=https://admin-staging.up.railway.app/privacy
PRIVACY_CHOICES_URL=https://admin-staging.up.railway.app/privacy/choices
PRIVACY_CONTACT_EMAIL=privacy@mail.devnamu.com

APP_BASE_URL=expirymate://
DEFAULT_OWNER_KEY=demo-user

# SMTP — configure before email auth flows
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=
SMTP_FROM="Jango <noreply@mail.devnamu.com>"

# OAuth — optional until providers are enabled
APPLE_OAUTH_CLIENT_ID=com.expirymate.mobile
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
KAKAO_OAUTH_CLIENT_ID=
KAKAO_OAUTH_CLIENT_SECRET=
NAVER_OAUTH_CLIENT_ID=
NAVER_OAUTH_CLIENT_SECRET=
OAUTH_PROVIDER_REDIRECT_URI=https://api-staging.up.railway.app/oauth/callback
OAUTH_APP_RETURN_URIS=expirymate://oauth

# OpenAI — required while RECIPE_AI_ENABLED is on
OPENAI_API_KEY=
RECIPE_AI_MODEL=gpt-5.4-mini
RECIPE_AI_ENABLED=true
RECIPE_RATE_LIMIT_MAX=3
RECIPE_RATE_LIMIT_WINDOW_SECONDS=60
RECIPE_DAILY_QUOTA=20
RECIPE_CACHE_TTL_SECONDS=21600
RECIPE_DAILY_COST_LIMIT_USD=1
RECIPE_GLOBAL_DAILY_COST_LIMIT_USD=10
RECIPE_MAX_INFLIGHT=5
RECIPE_AI_MAX_OUTPUT_TOKENS=2500
RECIPE_AI_INPUT_COST_PER_1M_TOKENS=0.25
RECIPE_AI_CACHED_INPUT_COST_PER_1M_TOKENS=0.025
RECIPE_AI_OUTPUT_COST_PER_1M_TOKENS=2

AI_DATA_NOTICE_VERSION=ai-data-notice-v2
PUSH_REMINDER_SCHEDULER_ENABLED=false

# IAP — production-env requires store environment=production; sandbox receipts need IAP_ALLOW_SANDBOX_PURCHASES=true only for deliberate QA
IAP_ALLOWED_PRODUCT_IDS=expirymate_premium_monthly,expirymate_premium_yearly
IAP_ALLOW_SANDBOX_PURCHASES=false
APPLE_BUNDLE_ID=com.expirymate.mobile
APPLE_APP_STORE_ENVIRONMENT=production
APPLE_APP_STORE_ISSUER_ID=
APPLE_APP_STORE_KEY_ID=
APPLE_APP_STORE_PRIVATE_KEY=
GOOGLE_PLAY_PACKAGE_NAME=com.expirymate.mobile
GOOGLE_PLAY_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PLAY_SERVICE_ACCOUNT_PRIVATE_KEY=

# Optional observability — see docs/PROJECT.md §5 Sentry
SENTRY_DSN=
GIT_SHA=
APP_VERSION=0.1.0

# ─── Admin Service Build Args (Railway → admin → Build Variables) ───
# Required for Docker image build (apps/admin/Dockerfile has no defaults).
NEXT_PUBLIC_API_BASE_URL=https://api-staging.up.railway.app
NEXT_PUBLIC_APP_ENV=production
PRIVACY_CONTACT_EMAIL=privacy@mail.devnamu.com
# SENTRY_DSN=...                    # jango-admin
# NEXT_PUBLIC_SENTRY_DSN=...        # same DSN as SENTRY_DSN (client)
