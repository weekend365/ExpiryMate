# Railway Staging — API Service Variables
# Copy values into Railway dashboard → api service → Variables
# Replace ALL placeholders before deploy.

NODE_ENV=production
PORT=4000

# Railway Postgres — use Variable Reference: ${{postgres.DATABASE_URL}}
DATABASE_URL=

# Generate: openssl rand -base64 48
AUTH_TOKEN_SECRET=
AUTH_ALLOW_DEV_FALLBACK=false
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_DAYS=30

# Set AFTER Admin service gets Railway domain (see docs/PROJECT.md §5)
CORS_ORIGIN_ADMIN=https://YOUR-ADMIN.up.railway.app
CORS_ORIGIN_MOBILE=expirymate://
ADMIN_BASE_URL=https://YOUR-ADMIN.up.railway.app
PRIVACY_POLICY_URL=https://YOUR-ADMIN.up.railway.app/privacy
PRIVACY_CHOICES_URL=https://YOUR-ADMIN.up.railway.app/privacy/choices
PRIVACY_CONTACT_EMAIL=your-real-email@example.com

APP_BASE_URL=expirymate://
DEFAULT_OWNER_KEY=demo-user

# SMTP — Step C (leave empty blocks email auth until configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ExpiryMate <no-reply@your-email-domain.com>

# OAuth — Step C (optional for initial API boot if using placeholders below)
APPLE_OAUTH_CLIENT_ID=com.expirymate.mobile
GOOGLE_OAUTH_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
KAKAO_OAUTH_CLIENT_ID=your-kakao-rest-api-key

# OpenAI — required for recipe AI (Step C)
OPENAI_API_KEY=sk-proj-...

# Recipe limits (defaults OK for staging)
RECIPE_AI_MODEL=gpt-5.4-mini
RECIPE_RATE_LIMIT_MAX=3
RECIPE_RATE_LIMIT_WINDOW_SECONDS=60
RECIPE_DAILY_QUOTA=20
RECIPE_CACHE_TTL_SECONDS=21600
RECIPE_DAILY_COST_LIMIT_USD=1
RECIPE_AI_MAX_OUTPUT_TOKENS=2500
RECIPE_AI_INPUT_COST_PER_1M_TOKENS=0.25
RECIPE_AI_CACHED_INPUT_COST_PER_1M_TOKENS=0.025
RECIPE_AI_OUTPUT_COST_PER_1M_TOKENS=2

AI_DATA_NOTICE_VERSION=ai-data-notice-v1
PUSH_REMINDER_SCHEDULER_ENABLED=false

# IAP — required by production-env.ts even if IAP not launched yet
IAP_ALLOWED_PRODUCT_IDS=expirymate_premium_monthly,expirymate_premium_yearly
APPLE_BUNDLE_ID=com.expirymate.mobile
APPLE_APP_STORE_ENVIRONMENT=sandbox
APPLE_APP_STORE_ISSUER_ID=69a6de70-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
APPLE_APP_STORE_KEY_ID=XXXXXXXXXX
APPLE_APP_STORE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIGTAgEAMBMG...\n-----END PRIVATE KEY-----
GOOGLE_PLAY_PACKAGE_NAME=com.expirymate.mobile
GOOGLE_PLAY_SERVICE_ACCOUNT_EMAIL=iap-verifier@your-project.iam.gserviceaccount.com
GOOGLE_PLAY_SERVICE_ACCOUNT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBg...\n-----END PRIVATE KEY-----

# Optional
SENTRY_DSN=
GIT_SHA=
APP_VERSION=0.1.0

# ─── Admin Service Build Args (Railway → admin → Build Variables) ───
# NEXT_PUBLIC_API_BASE_URL=https://YOUR-API.up.railway.app
# NEXT_PUBLIC_APP_ENV=production
# PRIVACY_CONTACT_EMAIL=your-real-email@example.com
